ENV=dev
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6-v1:0

# Leave empty unless running against a local DynamoDB container
DYNAMO_ENDPOINT=

# Cognito (fill when you deploy)
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# S3 bucket for food photos
FOOD_PHOTOS_BUCKET=nutriwise-food-photos-dev
