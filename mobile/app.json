{
  "expo": {
    "name": "NutriWise",
    "slug": "nutriwise",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "nutriwise",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nutriwise.app",
      "infoPlist": {
        "NSCameraUsageDescription": "NutriWise uses the camera to photograph meals for calorie estimation.",
        "NSPhotoLibraryUsageDescription": "NutriWise accesses your photo library to analyze meal photos you've already taken."
      }
    },
    "android": {
      "package": "com.nutriwise.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
